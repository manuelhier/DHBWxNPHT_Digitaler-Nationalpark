# Setup / Deployment
AUTH_TOKEN=changeme                        # password for the AnythingLLM UI + API
ANYTHINGLLM_WORKSPACE_NAME=hohe-tauern

# Chatbot Core (AnythingLLM)
SERVER_PORT=3001
STORAGE_DIR="/app/server/storage"
UID='1000'
GID='1000'
JWT_SECRET="my-random-string-for-seeding"  # generate: openssl rand -hex 32

# LLM Provider
LLM_PROVIDER=groq

# Groq (cloud) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL_PREF=llama-3.1-8b-instant

# Ollama (local inference)
#COMPOSE_PROFILES=local-inference
#OLLAMA_BASE_PATH=http://ollama:11434
#OLLAMA_MODEL_PREF=MichelRosselli/apertus:8b-instruct-2509-q4_k_m
#OLLAMA_MODEL_TOKEN_LIMIT=8192

# For all available AnythingLLM options (alternative LLM providers, embedding engines,
# vector databases, etc.) see: anythingllm/env.example

# DISABLE_MODEL_CHANGING=true
# DISABLE_VIEW_CHAT_HISTORY=1